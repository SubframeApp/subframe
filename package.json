{
  "name": "subframe",
  "private": true,
  "scripts": {
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "ts": "turbo run ts",
    "test": "turbo run test"
  },
  "devDependencies": {
    "prettier": "2.8.8",
    "turbo": "2.5.6",
    "typescript": "5.8.3"
  },
  "packageManager": "npm@11.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "^24.0.0",
    "npm": "^11.0.0"
  }
}
